# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# v1 default: deepseek-reasoner (V3). Swap to deepseek-v4-pro / deepseek-v4-flash when V4 ships.
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_ADAPTER=v3

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Agent runtime
WORKING_TOKEN_BUDGET=200000
PRUNE_TRIGGER_PCT=80
SNIP_TRIGGER_PCT=85
MICRO_COMPACT_TRIGGER_PCT=90
LOG_LEVEL=info

# Memory location (relative to cwd, OpenClaw-style)
MEMORY_DIR=.myceliate
