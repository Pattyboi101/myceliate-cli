# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# v1.5 Phase 2: model selection is automatic (Anamorph/Teleomorph routing).
# Uncomment to override globally — bypasses Anamorph/Teleomorph role routing.
# DEEPSEEK_MODEL=deepseek-v4-pro  # optional override; bypasses Anamorph/Teleomorph routing
DEEPSEEK_ADAPTER=v3

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Agent runtime
WORKING_TOKEN_BUDGET=200000
PRUNE_TRIGGER_PCT=80
SNIP_TRIGGER_PCT=85
MICRO_COMPACT_TRIGGER_PCT=90
LOG_LEVEL=info

# Memory location (relative to cwd, OpenClaw-style)
MEMORY_DIR=.myceliate

# MCP server lifecycle (Phase 3 Exoenzyme)
# MCP_INITIALIZE_TIMEOUT_MS=5000  # max wait for MCP server initialize handshake (Phase 3 mcpLifecycle default)
# MCP_TEARDOWN_GRACE_MS=2000      # SIGTERM-then-SIGKILL grace period for MCP server children (Phase 3 mcpLifecycle default)
# MCP_CALL_TIMEOUT_MS=30000       # max wait for MCP tool call response — protects ReAct loop from hanging server I/O (Phase 3 McpClient default; per-spore override via manifest mcp_server.call_timeout_ms)
