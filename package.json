{
  "name": "myceliate-cli",
  "version": "0.1.0",
  "description": "Autonomous DeepSeek V4 CLI agent. Thin Agent / Fat Platform architecture.",
  "type": "module",
  "bin": {
    "myc": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --dir tests/integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "queue:worker": "tsx src/queue/worker.ts",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "bullmq": "^5.13.0",
    "ink": "^5.0.1",
    "ioredis": "^5.4.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.2",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
