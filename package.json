{
  "name": "myceliate-cli",
  "version": "0.1.0",
  "description": "Autonomous DeepSeek V4 CLI agent. Thin Agent / Fat Platform architecture.",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Pattyboi101/myceliate-cli.git"
  },
  "type": "module",
  "bin": {
    "myceliate": "bin/myceliate.mjs"
  },
  "main": "dist/index.js",
  "files": [
    "bin",
    "dist",
    "spores",
    "src",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "queue:worker": "tsx src/queue/worker.ts",
    "redis:up": "docker compose up -d redis 2>/dev/null || docker run -d --rm --name myceliate-redis -p 6379:6379 redis:7-alpine redis-server --save 60 1 --loglevel warning",
    "redis:down": "docker compose down 2>/dev/null || docker rm -f myceliate-redis"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "bullmq": "^5.13.0",
    "dotenv": "^17.4.2",
    "ink": "^5.0.1",
    "ioredis": "^5.4.1",
    "react": "^18.3.1",
    "yaml": "^2.8.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.2",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  }
}
